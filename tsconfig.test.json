  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "outDir": ".tmp-tests",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["node"]
  },
  "include": [
    "src/vite-env.d.ts",
    "tests/**/*.ts",
    "src/lib/meeting/programming-language.ts",
    "src/lib/meeting/task-taxonomy.ts"
  ]
